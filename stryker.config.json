{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["progress", "clear-text", "json", "html"],
  "coverageAnalysis": "perTest",
  "mutate": [
    "scripts/lib/**/*.mjs"
  ],
  "thresholds": {
    "high": 90,
    "low": 85,
    "break": 80
  },
  "incremental": true
}
